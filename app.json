{
  "expo": {
    "name": "KGP Presence",
    "slug": "attendance-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/splash-icon-light.png",
    "scheme": "attendancetracker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["instagram", "linkedin"] // allows canOpenURL checks
      },
      "icon": {
        "dark": "./assets/icons/ios-dark.png",
        "light": "./assets/icons/ios-light.png",
        "tinted": "./assets/icons/ios-tinted.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "monochromeImage": "./assets/icons/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kratinsoni.attendancetracker",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "attendancetracker" // ← only your own app's scheme
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon-dark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/icons/splash-icon-light.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/notification-icon.png",
          "color": "#135bec",
          "androidMode": "default",
          "androidCollapsedTitle": "KGP Presence"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-background-task",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f727d7ff-23fe-459d-8ec3-df6d6375f007"
      }
    },
    "owner": "kgp-presence"
  }
}
